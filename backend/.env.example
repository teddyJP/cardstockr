# Database (use localhost when running Python on your machine; use db when in Docker)
DATABASE_URL=postgresql+psycopg2://tcg_user:tcg_pass@localhost:5432/tcg_db

# eBay Finding API (required for scripts/ingest_ebay_all_pokemon.py)
EBAY_APP_ID=YourAppId-SBX-xxxxxxxx
EBAY_DEV_ID=your-dev-id-optional
EBAY_SANDBOX=true
EBAY_GLOBAL_ID=EBAY_US

# eBay Marketplace Account Deletion (required for production keyset; use your deployed base URL)
# EBAY_ACCOUNT_DELETION_TOKEN=your-32-to-80-char-random-string
# EBAY_ACCOUNT_DELETION_ENDPOINT_URL=https://your-api.example.com/api/webhooks/ebay/account-deletion

# Optional: live exchange rates (leave blank to use fallback rates)
# EXCHANGE_RATE_API_URL=https://api.exchangerate-api.com/v4/latest/USD
